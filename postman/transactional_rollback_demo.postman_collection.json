                  "value": "10"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Run demo with transaction",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 500', function () {",
                  "  pm.response.to.have.status(500);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/demo/with-tx?prefix={{demoPrefixWithTx}}",
