            }
          },
          "response": []
        },
        {
          "name": "Count users with transaction",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Rollback keeps count at zero with transaction', function () {",
                  "  var count = Number(pm.response.text());",
                  "  pm.expect(count).to.eql(0);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/demo/count?prefix={{demoPrefixWithTx}}",
              "host": [
