    {
      "name": "Demo Transaction Rollback",
      "item": [
        {
          "name": "Run demo without transaction",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 500', function () {",
                  "  pm.response.to.have.status(500);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/demo/no-tx?prefix={{demoPrefixNoTx}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "demo",
                "no-tx"
              ],
              "query": [
                {
                  "key": "prefix",
                  "value": "{{demoPrefixNoTx}}"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Count users without transaction",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('At least one record persisted without transaction', function () {",
                  "  var count = Number(pm.response.text());",
                  "  pm.expect(count).to.be.above(0);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/demo/count?prefix={{demoPrefixNoTx}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "demo",
                "count"
              ],
              "query": [
                {
                  "key": "prefix",
                  "value": "{{demoPrefixNoTx}}"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "List users without transaction",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response is an array', function () {",
                  "  pm.expect(pm.response.json()).to.be.an('array');",
                  "});",
                  "pm.test('Without transaction list contains records', function () {",
                  "  pm.expect(pm.response.json().length).to.be.above(0);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/demo/users?prefix={{demoPrefixNoTx}}&page=0&size=10",
              "host": [
                "{{baseUrl}}"
              ],
